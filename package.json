{
	"name": "portafolio-jaime_burgos_tejada",
	"description": "portafolio",
	"version": "1.1.0",
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build",
		"format": "prettier --write \"./src/**/*.{ts,json,html}\"",
		"start:pwa": "ng build --configuration production && http-server -p 8080 -c-1 dist/portafolio/browser",
		"production": "ng build --configuration production",
		"watch": "ng build --watch --configuration development",
		"test": "ng test",
		"sonar": "sonar-scanner",
		"dev:ssr": "ng serve",
		"serve:ssr": "node dist/portafolio/server/server.mjs",
		"build:ssr": "ng build --configuration production",
		"prerender": "ng build --configuration production",
		"lint": "ng lint",
		"prepare": "husky install",
		"lint-format": "npm run format && ng lint --fix",
		"pre-commit": "npm run lint-format && git add .",
		"vercel-build": "npm run build:ssr"
	},
	"private": true,
	"dependencies": {
		"@angular/common": "^22.0.4",
		"@angular/compiler": "^22.0.4",
		"@angular/core": "^22.0.4",
		"@angular/platform-browser": "^22.0.4",
		"@angular/platform-server": "^22.0.4",
		"@angular/router": "^22.0.4",
		"@angular/service-worker": "^22.0.4",
		"@angular/ssr": "^22.0.4",
		"@fortawesome/angular-fontawesome": "^5.0.0",
		"@fortawesome/fontawesome-svg-core": "^6.7.2",
		"@fortawesome/free-brands-svg-icons": "^6.7.2",
		"@fortawesome/free-solid-svg-icons": "^6.7.2",
		"@ngx-translate/core": "^18.0.0",
		"@ngx-translate/http-loader": "^18.0.0",
		"express": "^4.22.2",
		"ngx-typed-writer": "^1.6.0",
		"rxjs": "~7.8.2",
		"tslib": "^2.8.1",
		"zone.js": "~0.16.2"
	},
	"devDependencies": {
		"@angular-eslint/builder": "22.0.0",
		"@angular-eslint/eslint-plugin": "22.0.0",
		"@angular-eslint/eslint-plugin-template": "22.0.0",
		"@angular-eslint/schematics": "22.0.0",
		"@angular-eslint/template-parser": "22.0.0",
		"@angular/build": "^22.0.4",
		"@angular/cli": "~22.0.4",
		"@angular/compiler-cli": "^22.0.4",
		"@tailwindcss/aspect-ratio": "^0.4.2",
		"@tailwindcss/forms": "^0.5.11",
		"@types/express": "^4.17.25",
		"@types/node": "^24.10.2",
		"@typescript-eslint/eslint-plugin": "8.61.1",
		"@typescript-eslint/parser": "8.61.1",
		"angular-cli-ghpages": "^3.1.0",
		"angular-eslint": "^22.0.0",
		"autoprefixer": "^10.5.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^9.1.2",
		"eslint-plugin-prettier": "^5.5.6",
		"husky": "^9.1.7",
		"jsdom": "^28.0.0",
		"prettier": "^3.8.4",
		"pretty-quick": "^3.1.3",
		"sonar-scanner": "^3.1.0",
		"tailwindcss": "^3.4.18",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.61.1",
		"vitest": "^4.0.15"
	},
	"overrides": {
		"@angular/build": {
			"@babel/core": "7.29.7"
		}
	}
}
