{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"cli": {
		"packageManager": "npm",
		"schematicCollections": ["@angular-eslint/schematics"]
	},
	"newProjectRoot": "projects",
	"projects": {
		"portafolio": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				}
			},
			"root": "",
			"sourceRoot": "src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular/build:application",
					"options": {
						"outputPath": "dist/portafolio",
						"index": "src/index.html",
						"browser": "src/main.ts",
						"polyfills": [],
						"tsConfig": "tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": ["src/favicon.ico", "src/assets", "src/manifest.webmanifest", "src/robots.txt"],
						"styles": ["src/assets/fonts/fonts.css", "src/styles.scss"],
						"scripts": [],
						"serviceWorker": "ngsw-config.json",
						"server": "src/main.server.ts",
						"outputMode": "server",
						"security": {
							"allowedHosts": []
						},
						"ssr": {
							"entry": "src/server.ts"
						}
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "500kB",
									"maximumError": "3MB"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "4kB",
									"maximumError": "8kB"
								}
							],
							"outputHashing": "all"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular/build:dev-server",
					"configurations": {
						"production": {
							"buildTarget": "portafolio:build:production"
						},
						"development": {
							"buildTarget": "portafolio:build:development"
						}
					},
					"defaultConfiguration": "development"
				},
				"extract-i18n": {
					"builder": "@angular/build:extract-i18n",
					"options": {
						"buildTarget": "portafolio:build"
					}
				},
				"test": {
					"builder": "@angular/build:unit-test"
				},
				"deploy": {
					"builder": "angular-cli-ghpages:deploy"
				},
				"lint": {
					"builder": "@angular-eslint/builder:lint",
					"options": {
						"lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
					}
				}
			}
		}
	}
}
